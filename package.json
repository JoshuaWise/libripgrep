{
	"name": "libripgrep",
	"version": "0.1.0",
	"description": "Native bindings for ripgrep",
	"author": "Joshua Wise <joshuathomaswise@gmail.com>",
	"homepage": "https://github.com/JoshuaWise/libripgrep#readme",
	"repository": {
		"type": "git",
		"url": "git://github.com/JoshuaWise/libripgrep.git"
	},
	"license": "MIT",
	"type": "commonjs",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./linux-x64": {
			"types": "./dist/linux-x64.d.ts",
			"default": "./dist/linux-x64.js"
		},
		"./linux-arm64": {
			"types": "./dist/linux-arm64.d.ts",
			"default": "./dist/linux-arm64.js"
		},
		"./darwin-x64": {
			"types": "./dist/darwin-x64.d.ts",
			"default": "./dist/darwin-x64.js"
		},
		"./darwin-arm64": {
			"types": "./dist/darwin-arm64.d.ts",
			"default": "./dist/darwin-arm64.js"
		}
	},
	"scripts": {
		"test": "jest",
		"prepare": "tsc",
		"watch": "tsc --watch",
		"build:native": "bash scripts/build-native.sh",
		"prettier": "prettier --write src/** test/** bench/**",
		"rust-fmt": "cargo fmt --manifest-path native/Cargo.toml",
		"rust-test": "cargo test --manifest-path native/Cargo.toml",
		"clean": "rm -rf node_modules dist prebuilds native/target"
	},
	"files": [
		"src/**",
		"dist/**",
		"prebuilds/**"
	],
	"dependencies": {},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"@types/node": "^25.3.5",
		"jest": "^30.2.0",
		"prettier": "^3.8.1",
		"ts-jest": "^29.4.6",
		"typescript": "^5.9.3"
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node"
	}
}
