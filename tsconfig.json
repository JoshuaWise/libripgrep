{
	"include": ["./src"],
	"compilerOptions": {
		"outDir": "./dist",
		"target": "es2024",
		"lib": ["es2024"],
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"resolveJsonModule": false,
		"declaration": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noEmitOnError": false,
		"forceConsistentCasingInFileNames": true
	}
}
